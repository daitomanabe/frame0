{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frame0.local/schema/scene.v0.json",
  "title": "FRAME0 Scene Manifest v0",
  "type": "object",
  "required": ["name", "version", "runtime", "clock", "nodes", "outputs"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "runtime": { "const": "frame0" },
    "permissions": { "$ref": "permission.schema.json" },
    "clock": {
      "type": "object",
      "required": ["primary", "fallback"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "fallback": { "type": "string", "minLength": 1 },
        "fixed_step_ns": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    },
    "nodes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "component": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "input": { "type": "string" },
        "inputs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "selector": { "type": "object" },
        "mode": { "type": "string" },
        "pixel_format": { "type": "string" },
        "shader": { "type": "string" },
        "params": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}

