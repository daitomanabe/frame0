{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frame0.local/schema/error.v0.json",
  "title": "FRAME0 Error v0",
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "severity", "message", "suggestions"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "enum": ["info", "warning", "error", "fatal"] },
        "resource": { "type": "string" },
        "message": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

