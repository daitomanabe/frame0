{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frame0.local/schema/graph.v0.json",
  "title": "FRAME0 Graph v0",
  "type": "object",
  "required": ["nodes", "edges", "topological_order", "diagnostics"],
  "properties": {
    "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "items": { "$ref": "#/$defs/edge" } },
    "topological_order": { "type": "array", "items": { "type": "string" } },
    "diagnostics": { "type": "array" }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "kind", "type"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["input", "node", "output"] },
        "type": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "label": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

